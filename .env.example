NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TMDB_API_TOKEN=your-tmdb-read-access-token
# Optional: enables IMDb, Rotten Tomatoes, and Metacritic scores on title pages
OMDB_API_KEY=your-omdb-api-key
TRAKT_CLIENT_ID=your-trakt-client-id
TRAKT_CLIENT_SECRET=your-trakt-client-secret
# Production: https://YOUR-DOMAIN/api/integrations/trakt/callback
TRAKT_REDIRECT_URI=http://localhost:3000/api/integrations/trakt/callback
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TRAKT_TOKEN_ENCRYPTION_KEY=your-32-byte-base64-key
# Production: https://YOUR-DOMAIN (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CRON_SECRET=replace-with-a-long-random-secret
